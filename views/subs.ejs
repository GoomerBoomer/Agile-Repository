<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Subgroups – Hiroshi and Friends</title>
  </head>
  <body>

    <header class="site-header">
      <div class="header-inner">
        <div class="site-title">
          <a href="/"><img src="/images/logo.png" alt="Hiroshi and Friends" class="site-logo" /></a>
        </div>
        <nav class="header-nav">
          <a href="/" class="btn btn-outline">← Home</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <h2 class="section-heading">All Subgroups</h2>

      <% if (!subs || subs.length === 0) { %>
        <p class="no-posts">No subgroups yet. Create a post with a subgroup to add one.</p>
      <% } else { %>
        <div class="subs-list">
          <% subs.forEach(function(name) { %>
            <a class="sub-item" href="/subs/show/<%= encodeURIComponent(name) %>">
              <span class="sub-prefix">r/</span><%= name %>
            </a>
          <% }); %>
        </div>
      <% } %>
    </main>

    <footer class="site-footer">
      <p>Hiroshi and Friends &copy; 2026</p>
    </footer>

    <script src="/js/notifications.js"></script>
  </body>
</html>
