<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link href="/css/style.css" rel="stylesheet" />
    <title>Subs</title>
  </head>
  <body>
    <main>
      <div class="authOptions">
        <h1>Subgroups</h1>
        <a role="button" href="/">Home</a>
      </div>
      <div>
        <% if (!subs || subs.length === 0) { %>
        <p>No subgroups yet. Create a post with a subgroup to add one.</p>
        <% } else { %>
        <ul>
          <% subs.forEach(function (name) { %>
          <li>
            <a href="/subs/show/<%= encodeURIComponent(name) %>"><%= name %></a>
          </li>
          <% }); %>
        </ul>
        <% } %>
      </div>
    </main>
  </body>
</html>
