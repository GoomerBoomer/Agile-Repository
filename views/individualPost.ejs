<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link href="/css/style.css" rel="stylesheet" />
    <title>Post</title>
  </head>
  <body>
    <main>
      <div class="authOptions">
        <h1>View Post</h1>
        <a role="button" href="/">Home</a>
      </div>

      <article class="individualPost">
        <h2><a href="<%= post.link || '#' %>"><%= post.title %></a></h2>
        <p><%= post.description %></p>

        <p class="postMeta">
          Posted by <strong><%= post.creator.uname %></strong> in
          <a href="/subs/show/<%= encodeURIComponent(post.subgroup) %>">
            <%= post.subgroup %>
          </a>
          at <%= new Date(post.timestamp).toLocaleString() %>
        </p>

        <div class="voteRow">
          <span class="voteTotal">Score: <%= voteTotal %></span>
          <% if (user) { %>
          <form method="POST" action="/posts/vote/<%= post.id %>">
            <input type="hidden" name="setvoteto" value="<%= myVote === 1 ? 0 : 1 %>" />
            <button
              type="submit"
              class="voteButton upvote <%= myVote === 1 ? 'activeVote' : '' %>"
            >
              Up
            </button>
          </form>

          <form method="POST" action="/posts/vote/<%= post.id %>">
            <input type="hidden" name="setvoteto" value="<%= myVote === -1 ? 0 : -1 %>" />
            <button
              type="submit"
              class="voteButton downvote <%= myVote === -1 ? 'activeVote' : '' %>"
            >
              Down
            </button>
          </form>
          <% } %>
        </div>

        <% if (isOwner) { %>
        <div class="ownerRow">
          <a role="button" href="/posts/edit/<%= post.id %>">Edit</a>
          <a role="button" class="secondary" href="/posts/deleteconfirm/<%= post.id %>">
            Delete
          </a>
        </div>
        <% } %>
      </article>

      <section>
        <h3>Comments</h3>

        <% if (user) { %>
        <form method="POST" action="/posts/comment-create/<%= post.id %>">
          <label>
            Add Comment
            <textarea name="description" required></textarea>
          </label>
          <button type="submit">Post Comment</button>
        </form>
        <% } else { %>
        <p><a href="/auth/login">Login</a> to comment or vote.</p>
        <% } %>

        <% if (post.comments.length === 0) { %>
        <p>No comments yet.</p>
        <% } %>

        <% post.comments.forEach(comment => { %>
        <article>
          <p><%= comment.description %></p>
          <small>
            by <strong><%= comment.creator.uname %></strong>
            at <%= new Date(comment.timestamp).toLocaleString() %>
          </small>
        </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>
