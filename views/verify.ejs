<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Verify Email – Hiroshi and Friends</title>
  </head>
  <body>

    <header class="site-header">
      <div class="header-inner">
        <div class="site-title">
          <a href="/"><img src="/images/logo.png" alt="Hiroshi and Friends" class="site-logo" /></a>
        </div>
      </div>
    </header>

    <main class="main-content main-content--centered">

      <div class="form-card form-card--auth">
        <h2 class="page-heading">Verify Your Email</h2>

        <p class="verify-info">
          A 4-digit code has been sent to <strong><%= email %></strong>. Enter it below to confirm your account.
        </p>

        <% if (error) { %>
          <p class="errorBox"><%= error %></p>
        <% } %>

        <form action="/auth/verify" method="post">
          <input type="hidden" name="email" value="<%= email %>" />

          <div class="form-group">
            <label for="code">Verification Code</label>
            <input
              type="text"
              id="code"
              name="code"
              placeholder="1234"
              maxlength="4"
              pattern="\d{4}"
              required
              class="input-code"
            />
          </div>

          <button type="submit" class="btn btn-full">Verify</button>
        </form>

        <p class="form-footer-text">Wrong email? <a href="/auth/signup">Go back</a></p>
      </div>

    </main>

    <footer class="site-footer">
      <p>Hiroshi and Friends &copy; 2026</p>
    </footer>

  </body>
</html>
