<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link href="/css/style.css" rel="stylesheet" />
    <title>Homepage</title>
  </head>
  <body>
    <main>
      <div class="authOptions">
        <h1>Homepage</h1>
        <% if (!user) { %>
        <a role="button" href="/auth/login">Login</a>
        <% } else { %>
        <a role="button" href="/auth/logout">Logout</a>
        <% } %>
      </div>
      <h2>Welcome, <%= user?.uname || "Visitor" %></h2>
      <div>
        <p>All Posts</p>
        <% posts.forEach(post => { %>
        <div class="individualPost">
          <a href="/posts/show/<%=post.id%>"><%= post.title %></a>
          <p><%= post.description %></p>
          <p class="postMeta">
            by <strong><%= post.creator.uname %></strong> in
            <a href="/subs/show/<%= encodeURIComponent(post.subgroup) %>">
              <%= post.subgroup %>
            </a>
          </p>

          <div class="voteRow">
            <span class="voteTotal">Score: <%= post.voteTotal %></span>
            <% if (user) { %>
            <form method="POST" action="/posts/vote/<%= post.id %>">
              <input
                type="hidden"
                name="setvoteto"
                value="<%= post.myVote === 1 ? 0 : 1 %>"
              />
              <button
                type="submit"
                class="voteButton upvote <%= post.myVote === 1 ? 'activeVote' : '' %>"
              >
                Up
              </button>
            </form>
            <form method="POST" action="/posts/vote/<%= post.id %>">
              <input
                type="hidden"
                name="setvoteto"
                value="<%= post.myVote === -1 ? 0 : -1 %>"
              />
              <button
                type="submit"
                class="voteButton downvote <%= post.myVote === -1 ? 'activeVote' : '' %>"
              >
                Down
              </button>
            </form>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>

      <div>
        <a href="/subs/list">Subgroups</a>
      </div>

      <% if (user) { %>
      <div>
        <a role="button" href="/posts/create">Create Post</a>
      </div>
      <% } %>
    </main>
  </body>
</html>
