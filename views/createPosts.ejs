<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Create Post – Hiroshi and Friends</title>
  </head>
  <body>

    <header class="site-header">
      <div class="header-inner">
        <div class="site-title">
          <a href="/"><img src="/images/logo.png" alt="Hiroshi and Friends" class="site-logo" /></a>
        </div>
        <nav class="header-nav">
          <a href="/" class="btn btn-outline">← Home</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <h2 class="page-heading">Create a Post</h2>

      <% if (error) { %>
        <p class="errorBox"><%= error %></p>
      <% } %>

      <div class="form-card">
        <form method="POST" action="/posts/create">

          <div class="form-group">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" required value="<%= formData?.title || '' %>" />
          </div>

          <div class="form-group">
            <label for="link">Link <span class="optional">(optional)</span></label>
            <input type="url" id="link" name="link" placeholder="https://example.com" value="<%= formData?.link || '' %>" />
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4"><%= formData?.description || '' %></textarea>
          </div>

          <div class="form-group">
            <label for="subgroup">Subgroup</label>
            <input type="text" id="subgroup" name="subgroup" required placeholder="e.g. coding" value="<%= formData?.subgroup || '' %>" />
          </div>

          <button type="submit" class="btn">Create Post</button>
        </form>
      </div>
    </main>

    <footer class="site-footer">
      <p>Hiroshi and Friends &copy; 2025</p>
    </footer>

  </body>
</html>
