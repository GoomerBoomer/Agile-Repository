<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Delete Post – Hiroshi and Friends</title>
  </head>
  <body>

    <header class="site-header">
      <div class="header-inner">
        <div class="site-title">
          <a href="/"><img src="/images/logo.png" alt="Hiroshi and Friends" class="site-logo" /></a>
        </div>
        <nav class="header-nav">
          <a href="/posts/show/<%= post.id %>" class="btn btn-outline">← Cancel</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <h2 class="page-heading">Delete Post?</h2>

      <div class="post-card post-card--full">
        <div class="post-body">
          <p class="post-title-large"><%= post.title %></p>
          <p class="post-desc"><%= post.description %></p>
          <p class="post-meta warning-text">⚠️ This action cannot be undone.</p>
        </div>
      </div>

      <div class="confirm-actions">
        <form method="POST" action="/posts/delete/<%= post.id %>">
          <input type="hidden" name="confirmDelete" value="yes" />
          <button type="submit" class="btn btn-danger">Yes, Delete Post</button>
        </form>
        <form method="POST" action="/posts/delete/<%= post.id %>">
          <input type="hidden" name="confirmDelete" value="no" />
          <button type="submit" class="btn btn-outline">No, Keep Post</button>
        </form>
      </div>
    </main>

    <footer class="site-footer">
      <p>Hiroshi and Friends &copy; 2025</p>
    </footer>

  </body>
</html>
