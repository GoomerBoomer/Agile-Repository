<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Login – Hiroshi and Friends</title>
  </head>
  <body>

    <header class="site-header">
      <div class="header-inner">
        <div class="site-title">
          <a href="/"><img src="/images/logo.png" alt="Hiroshi and Friends" class="site-logo" /></a>
        </div>
      </div>
    </header>

    <main class="main-content main-content--centered">

      <div class="form-card form-card--auth">
        <h2 class="page-heading">Login</h2>

        <% if (typeof success !== 'undefined' && success) { %>
          <p class="successBox"><%= success %></p>
        <% } %>

        <form action="/auth/login" method="post">
          <div class="form-group">
            <label for="uname">Username</label>
            <input type="text" id="uname" name="uname" placeholder="Enter your username" />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="Enter your password" />
          </div>

          <button type="submit" class="btn btn-full">Login</button>
        </form>

        <p class="form-footer-text">Don't have an account? <a href="/auth/signup">Sign up</a></p>
      </div>

    </main>

    <footer class="site-footer">
      <p>Hiroshi and Friends &copy; 2026</p>
    </footer>

    <script src="/js/notifications.js"></script>
  </body>
</html>
